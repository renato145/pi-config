{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",

  "piInfrastructureReadPaths": [
    "/home/renato/.local/share/nvm/v24.14.0/lib/node_modules/@earendil-works/pi-coding-agent"
  ],

  "permission": {
    "*": "ask",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "read": "allow",
    "write": "ask",
    "edit": "ask",
    "find": "allow",
    "grep": "allow",
    "ls": "allow",
    "web_search": "allow",
    "web_fetch": "allow",
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "rm -rf /": "deny",
      "rm -rf ~/*": "deny",
      "sudo *": "ask",
      "git status": "allow",
      "git diff": "allow",
      "git log*": "allow",
      "git *": "ask",
      "find *": "allow",
      "sort *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "readlink *": "allow",
      "dirname *": "allow",
      "cargo check*": "allow",
      "cargo clippy*": "allow",
      "cargo fmt*": "allow",
      "mkdir *": "ask",
      "touch *": "ask"
    },
    "external_directory": "ask"
  }
}
