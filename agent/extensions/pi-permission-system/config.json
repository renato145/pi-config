{
  "permission": {
    "*": "ask",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "read": "allow",
    "write": "ask",
    "edit": "ask",
    "find": "allow",
    "grep": "allow",
    "ls": "allow",
    "bash": {
      "rm -rf *": "deny",
      "sudo *": "ask",
      "git status": "allow",
      "git *": "ask"
    },
    "external_directory": "ask"
  }
}
